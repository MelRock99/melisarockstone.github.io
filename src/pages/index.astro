---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="MelisaRockStone Music">

  <!-- HERO BANNER -->
  <div class="hero-banner">
    <img
      src={`${import.meta.env.BASE_URL}hero.jpg`}
      alt="Melisa Rockstone live performance"
    />
  </div>

  <!-- INTRO CARD -->
  <section class="card">
    <h1 style="margin:0 0 8px;">MelisaRockStone Music</h1>
    <p style="margin:0;opacity:.92;">
      Gritty blues-rooted rock with Florida heat and bayou soul.
    </p>

    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;">
      <a class="button" href="events/">Events</a>
      <a class="button" href="merch/">Merch</a>
      <a class="button" href="mailto:Melisarockstone@gmail.com">Contact</a>
    </div>
  </section>

  <!-- DIVIDER BETWEEN HERO + BIO -->
  <div class="section-divider"></div>

  <!-- BIO SECTION -->
  <section class="card">
    <h2>Bio</h2>

    <p>
      I create blues-driven rock formed through real life — through hard seasons,
      rebuilding, and the kind of transformation that reshapes your character from the inside out.
    </p>

    <blockquote class="pull-quote">
      Forged through fire.<br />
      Rooted in truth.
    </blockquote>

    <p>
      Born and raised in Plant City, Florida, I carry the grit, rhythm,
      and backbone of the South into every note I write.
    </p>

    <p>
      I’m a self-producing artist. Guitar, vocals, flute, and modern production
      tools all stay in my hands so the music remains honest and unfiltered.
    </p>

    <p>
      Recording work has taken place in Florida and Morocco —
      environments that continue to shape the texture and direction of what I create.
    </p>

    <p>
      This music is not created just to make a lot of noise. It's built to ROCK you steady! 
    </p>

  <section class="card" style="text-align:center;">
  <h2>Get the Music First</h2>

  <p style="max-width:600px;margin:0 auto;opacity:.9;">
    New releases, unreleased tracks, and deeper pieces I don’t put anywhere else.
    If you feel the music — this is where it lands first.
  </p>

  <div style="margin-top:20px;">
    <a
      class="button"
      href="https://melisarockstone4real.substack.com/"
      target="_blank"
    >
      Join the List
    </a>
  </div>
</section>
<section class="card" style="text-align:center; margin-top:24px;">
  <h2>Support the Journey</h2>

  <p style="max-width:640px;margin:0 auto;opacity:.92;">
    If this music speaks to you, there’s a deeper side to it —
    early glimpses, private drops, and the world behind what’s being created.
  </p>

  <div style="margin-top:20px;">
    <a
      class="button"
      href="https://www.patreon.com/cw/melisarockstone"
      target="_blank"
      rel="noreferrer"
    >
      Join on Patreon
    </a>
  </div>
</section>
</BaseLayout>
